spring:
  config:
    activate:
      on-profile: lcl

  devtools:
      restart:
        enabled: true
      livereload:
        enabled: true

  docker:
    compose:
      enabled: true
      lifecycle-management: start-and-stop

  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5432}/${DB_NAME:db-lcl}
    username: ${DB_USER:admin}
    password: ${DB_PASS:admin}

  jpa:
    show-sql: true
    properties:
      hibernate:
        generate_statistics: true

app:
  security:
    users:
      - name: ${ADMIN_NAME:admin}
        password: ${ADMIN_PASS:admin}
        role: ADMIN
      - name: ${USER_NAME:user}
        password: ${USER_PASS:user}
        role: USER

logging:
  level:
    web: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE
